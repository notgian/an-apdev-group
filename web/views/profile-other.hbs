{{#*inline "styles"}}
  <link rel="stylesheet" href="/css/profile.css">
{{/inline}}

<main class="profile-layout-wrapper">
    {{!-- Left Side: The Public Profile of the user being viewed --}}
    <div id="logged-in-view">
        <div class="user-header">
            <img src="{{profileData.avatar}}" 
                 id="profile-pic" class="avatar-large" alt="{{profileData.username}}'s Profile Picture">
            <h2 id="username-display">{{profileData.username}}</h2>
            <p id="user-desc">{{profileData.description}}</p>
            
            <button class="follow-btn" onclick="followUser('{{profileData._id}}')">Follow</button>
        </div>

        <div class="user-activity">
            <h3>Latest Reviews by {{profileData.username}}</h3>
            {{#each reviews}}
                <div class="review-item">
                    <strong>{{this.restaurantId.name}}</strong> {{#renderStarsHTML this.rating}}{{/renderStarsHTML}} <br /> "{{this.comment}}"
                </div>
            {{else}}
                <p class="review-item">No reviews posted yet.</p>
            {{/each}}
        </div>

        <div class="profile-actions">
            <button class="viewrev-btn" onclick="window.location.href='/profile/reviews/{{user._id}}'">View All Reviews</button>
        </div>
    </div>

    {{!-- Right Side: Sidebar for suggestions --}}
    <aside id="other-users" class="other-users">
        <h3>Other Foodies to Follow</h3>
        {{#each suggestedFoodies}}
            <div class="user-card">
                <img src="{{this.avatar}}" class="avatar-med" alt="{{this.username}}">
               <div class="user-card-info">
                    <p><a href="/profile/{{this._id}}"><strong>{{this.username}}</strong></a></p>
                    <p class="small-text">{{this.followers.length}} followers</p>
                </div>
                <button class="follow-btn" onclick="followUser('{{this._id}}')">Follow</button>
            </div>
        {{else}}
            <p>No suggestions available.</p>
        {{/each}}
    </aside>
</main>
