{{#*inline "styles"}}
  <link rel="stylesheet" href="/css/signlog.css">
{{/inline}}

<main class="form-container">
    <div class="auth-card">
        <h2>Create an Account</h2>
        <p class="subtitle">Join the 6-7-Ate-9 community!</p>
        
        {{!-- enctype is required for the file upload to work on the backend --}}
        <form id="signup-form" action="/signup" method="POST" enctype="multipart/form-data">
            <div class="input-group">
                <label for="signup-username">Username</label>
                {{!-- Added name="username" for backend access --}}
                <input type="text" name="username" id="signup-username" placeholder="Choose a unique username" required>
            </div>

            <div class="input-group">
                <label for="signup-password">Password</label>
                {{!-- Added name="password" for backend access --}}
                <input type="password" name="password" id="signup-password" placeholder="Min. 8 characters" required>
            </div>

            <div class="input-group">
                <label for="avatar">Profile Picture</label>
                {{!-- Added name="avatar" for the file upload --}}
                <input type="file" name="avatar" id="avatar" accept="image/*" class="file-input">
            </div>

            <div class="input-group">
                <label for="signup-desc">About You</label>
                {{!-- Added name="description" --}}
                <textarea name="description" id="signup-desc" placeholder="Tell us about your favorite eats..."></textarea>
            </div>

            <button type="submit" class="btn-main">Sign Up</button>
        </form>
        <p class="footer-text">Already have an account? <a href="/login">Log In</a></p>
    </div>
</main>