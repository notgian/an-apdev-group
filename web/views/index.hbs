{{#*inline "styles"}}
  <link rel="stylesheet" href="/css/home.css">
{{/inline}}

<section class="search-section">
    <div class="search-bar-container-home">
        <form action="/search" method="GET" style="display: flex; width: 100%; align-items: center;">
            <input type="text" name="query" placeholder="Looking for a restaurant or area..." id="search-input">
            <button type="submit" class="search-btn-home">Search</button>
        </form>
    </div>
</section>

<main class="content-container">
    <h2>TRENDING ESTABLISHMENTS</h2>
    
    <div id="establishment-grid" class="grid">
        {{!-- This loop replaces the manual list and pulls 5+ items from your database --}}
        {{#if establishments}}
            {{#each establishments}}
                <div class="card">
                    <h3>{{this.name}}</h3>
                    <p>{{#renderStarsHTML this.avgRating}}{{/renderStarsHTML}}</p>
                    <p>{{ this.category }} • {{this.location.city}}</p> {{! NOTE/TODO: Restaurants currently have no categories. }}
                    <p>₱{{this.priceRange.min}} - ₱{{this.priceRange.max}}</p>
                    <button onclick="window.location.href='/establishment/{{this._id}}';">Read Reviews</button>
                </div>        
            {{/each}}
        {{else}}
            <p class="empty-msg">No trending establishments at the moment.</p>
        {{/if}}
    </div>
</main>
