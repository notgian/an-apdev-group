<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title> {{ title }} </title>

        {{#each css}}
            <link href="{{this}}" rel="stylesheet">
        {{/each}}

        {{#each js}}
            <script defer src="{{this}}"></script>

        {{/each}}
    </head>
    <body>
        {{{ body }}}
    </body>
</html>
