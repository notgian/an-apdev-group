    <div class="advanced-search-container" style="background: white; padding: 15px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #f0b6d4;">
            <h3 style="color: #d14d72; margin-top: 0;">Filter Results</h3>
            <form action="/search" method="get" style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                <input type="hidden" name="query" value="{{query}}"> 

                <div class="input-group" style="margin-bottom: 0;">
                    <input type="text" name="city" placeholder="City (e.g. Makati)" value="{{location}}" style="padding: 8px; border-radius: 4px; border: 1px solid #ccc;">
                </div>

                <div class="input-group" style="margin-bottom: 0;">
                    <input type="number" name="minRating" placeholder="Min Rating (0-5)" min="0" max="5" style="padding: 8px; border-radius: 4px; border: 1px solid #ccc;">
                </div>

                <div class="input-group" style="margin-bottom: 0;">
                    <input type="number" name="minPrice" placeholder="Min Price (₱)" min="0" style="padding: 8px; border-radius: 4px; border: 1px solid #ccc; width: 120px;">
                    <span style="color: #666;">-</span>
                    <input type="number" name="maxPrice" placeholder="Max Price (₱)" min="0" style="padding: 8px; border-radius: 4px; border: 1px solid #ccc; width: 120px;">
                </div>

                <button type="submit" style="padding: 8px 15px;">Apply Filters</button>
            </form>
        </div>

    <h2 id="results-info">
        {{#if query}}
          {{#if location}}
            Searching "{{query}}" in "{{location}}": {{results.length}} result(s)
          {{else}}
            Searching for "{{query}}": {{results.length}} result(s)
          {{/if}}
        {{else if location}}
          Searching in "{{location}}": {{results.length}} result(s)
        {{else}}
          Search Results: {{results.length}} result(s)
        {{/if}}
      </h2>

      <div id="search-results-list">
        {{#if results.length}}
          {{#each results}}
            <div class="card">
              <div class="card-left">
                <img src="{{this.imageSrc}}" alt="[{{this.name}} | establishment image]" class="card-img">
              </div>

              <div class="card-right">
                <h3>{{this.name}}</h3>
                <p>{{#renderStarsHTML this.avgRating}}{{/renderStarsHTML}}</p>
                <p>{{this.location.city}} • ₱{{this.priceRange.min}} - ₱{{this.priceRange.max}}</p>
                <p class="establishment-hours">Open from {{this.hours}}</p>

                <p class="establishment-about">
                  “{{truncate this.description 100}}”
                </p>

                <button>
                  <a href="/establishment/{{this._id}}" style="color: white; text-decoration: none;">Read More</a>
                </button>
              </div>
            </div>
          {{/each}}
        {{else}}
          <p>No results found.</p>
        {{/if}}
    </div>
